{
  # Internal PKI: Caddy generates its own CA and signs certs for all service subdomains.
  # Transport is encrypted even inside the tailnet — useful for multi-user org deployments.
  #
  # To avoid browser warnings, trust the root CA on your devices:
  #   cat /opt/monitoring-caddy/ca.crt   (copy to your devices and install as trusted CA)
  #   macOS:  sudo security add-trusted-cert -d -r trustRoot -k /Library/Keychains/System.keychain ca.crt
  #   Linux:  sudo cp ca.crt /usr/local/share/ca-certificates/ && sudo update-ca-certificates
  #   Windows: certmgr.msc → Trusted Root Certification Authorities → Import
  # Or accept the browser warning (connection is still encrypted).
}

# Service subdomains — reachable from any tailnet-connected device over HTTPS.
# Each service resolves via MagicDNS extra_records (populated by headscale DNS reconcile).
# Caddy binds only to the Tailscale interface so these are never exposed publicly.

{% for service in internal_service_routes_effective | default([]) %}
{% set _upstream_ip = (hostvars[service.upstream_host].tailscale_ip | default('')) %}
{{ service.name }}.{{ headscale_magic_dns_base_domain }} {
  bind {{ tailscale_ip }}
  tls internal
  {% if _upstream_ip | trim != '' %}
  reverse_proxy {{ _upstream_ip }}:{{ service.upstream_port }}
  {% else %}
  respond "upstream {{ service.upstream_host }} has no tailscale_ip yet" 502
  {% endif %}
}
{% endfor %}
