#!/usr/bin/env bash
set -euo pipefail
export PATH="/usr/local/bin:$PATH"

# Backup restore drill
# Generated by Ansible — do not edit manually.
#
# Runs weekly via cron to verify backup integrity:
#  1. restic check on both backends
#  2. Restore latest snapshot to temp dir
#  3. Verify restored files exist and are non-empty
#  4. Clean up

ENV="{{ backup_env }}"
METRICS_DIR="{{ backup_textfile_dir }}"
CACHE_DIR="{{ backup_cache_dir }}"
DRILL_DIR="/tmp/backup-drill"

source {{ backup_base_dir }}/.env

export RESTIC_PASSWORD="{{ backup_restic_password }}"
export RESTIC_CACHE_DIR="${CACHE_DIR}"

overall_status=1

run_drill() {
  local service="$1"
  local repo="$2"
  local access_key="$3"
  local secret_key="$4"
  local backend_name="$5"

  export RESTIC_REPOSITORY="${repo}"
  export AWS_ACCESS_KEY_ID="${access_key}"
  export AWS_SECRET_ACCESS_KEY="${secret_key}"

  local drill_status=1

  echo "[drill][${service}] Checking ${backend_name} repo integrity..."
  if ! restic check --read-data-subset=1/10 2>&1; then
    echo "[drill][${service}] WARNING: Integrity check failed on ${backend_name}" >&2
    drill_status=0
  fi

  echo "[drill][${service}] Restoring latest snapshot from ${backend_name} to temp dir..."
  local restore_dir="${DRILL_DIR}/${service}/${backend_name}"
  rm -rf "${restore_dir}"
  mkdir -p "${restore_dir}"

  if restic restore latest --target "${restore_dir}" --tag "${service}" 2>&1; then
    # Verify files exist
    local file_count
    file_count=$(find "${restore_dir}" -type f | wc -l)
    if [[ ${file_count} -eq 0 ]]; then
      echo "[drill][${service}] WARNING: Restore produced no files on ${backend_name}" >&2
      drill_status=0
    else
      echo "[drill][${service}] OK: Restored ${file_count} files from ${backend_name}"
    fi
  else
    echo "[drill][${service}] WARNING: Restore failed on ${backend_name}" >&2
    drill_status=0
  fi

  rm -rf "${restore_dir}"

  # Write per-service drill metric
  cat > "${METRICS_DIR}/backup_drill_${service}.prom.tmp" <<METRICS
# HELP backup_drill_last_status Status of last backup drill (1=success, 0=failure)
# TYPE backup_drill_last_status gauge
backup_drill_last_status{service="${service}",env="${ENV}",backend="${backend_name}"} ${drill_status}
# HELP backup_drill_last_timestamp Unix timestamp of last drill run
# TYPE backup_drill_last_timestamp gauge
backup_drill_last_timestamp{service="${service}",env="${ENV}",backend="${backend_name}"} $(date +%s)
METRICS
  mv "${METRICS_DIR}/backup_drill_${service}.prom.tmp" "${METRICS_DIR}/backup_drill_${service}.prom"

  if [[ ${drill_status} -eq 0 ]]; then
    overall_status=0
  fi
}

echo "[drill] Starting backup restore drill at $(date -u +%Y-%m-%dT%H:%M:%SZ)"

mkdir -p "${DRILL_DIR}"

# Run drill for each service with a config file
for config_file in {{ backup_config_dir }}/*.yml; do
  [[ -f "${config_file}" ]] || continue
  service=$(basename "${config_file}" .yml)
  repo_name="${service}"
  if [[ "${service}" == "tailscale" ]]; then
    repo_name="${service}-{{ inventory_hostname }}"
  fi

  # Primary backend
  run_drill "${service}" \
    "s3:{{ backup_backends[0].endpoint }}/{{ backup_backends[0].bucket }}/${ENV}/${repo_name}" \
    "{{ backup_backends[0].access_key }}" \
    "{{ backup_backends[0].secret_key }}" \
    "primary"

{% if backup_backends | length > 1 and (backup_backends[1].access_key | default('') | trim) != '' %}
  # Secondary backend
  run_drill "${service}" \
    "s3:{{ backup_backends[1].endpoint }}/{{ backup_backends[1].bucket }}/${ENV}/${repo_name}" \
    "{{ backup_backends[1].access_key }}" \
    "{{ backup_backends[1].secret_key }}" \
    "secondary"
{% endif %}
done

rm -rf "${DRILL_DIR}"

if [[ ${overall_status} -eq 1 ]]; then
  echo "[drill] All drills PASSED at $(date -u +%Y-%m-%dT%H:%M:%SZ)"
else
  echo "[drill] Some drills FAILED at $(date -u +%Y-%m-%dT%H:%M:%SZ)" >&2
  exit 1
fi
