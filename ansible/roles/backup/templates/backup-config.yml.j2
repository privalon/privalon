# Backup configuration for {{ item.service_name }}
# Generated by Ansible — do not edit manually.

service_name: "{{ item.service_name }}"
env: "{{ backup_env }}"

targets:
{% for target in item.targets %}
  - name: "{{ target.name }}"
    type: "{{ target.type | default('directory') }}"
    path: "{{ target.path }}"
    description: "{{ target.description | default('') }}"
{% if target.exclude | default([]) | length > 0 %}
    exclude:
{% for excl in target.exclude %}
      - "{{ excl }}"
{% endfor %}
{% endif %}
{% endfor %}

{% if item.pre_backup | default([]) | length > 0 %}
pre_backup:
{% for hook in item.pre_backup %}
  - name: "{{ hook.name }}"
    command: "{{ hook.command }}"
{% endfor %}
{% endif %}

{% if item.post_backup | default([]) | length > 0 %}
post_backup:
{% for hook in item.post_backup %}
  - name: "{{ hook.name }}"
    command: "{{ hook.command }}"
{% endfor %}
{% endif %}

retention:
  keep_hourly: {{ (item.retention | default({})).keep_hourly | default(backup_retention_keep_hourly) }}
  keep_daily: {{ (item.retention | default({})).keep_daily | default(backup_retention_keep_daily) }}
  keep_weekly: {{ (item.retention | default({})).keep_weekly | default(backup_retention_keep_weekly) }}
  keep_monthly: {{ (item.retention | default({})).keep_monthly | default(backup_retention_keep_monthly) }}
  keep_yearly: {{ (item.retention | default({})).keep_yearly | default(backup_retention_keep_yearly) }}
