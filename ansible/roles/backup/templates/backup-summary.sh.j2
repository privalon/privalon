#!/usr/bin/env bash
set -euo pipefail
export PATH="/usr/local/bin:$PATH"

# Weekly Backup Health Summary
# Generated by Ansible — do not edit manually.
#
# Queries Prometheus for backup metrics and generates a summary report.
# Runs weekly via cron on the monitoring VM.

PROMETHEUS_URL="http://{{ tailscale_ip }}:9090"
ENV="{{ backup_env }}"
SUMMARY_FILE="/tmp/backup-summary-$(date +%Y%m%d).txt"

query_prometheus() {
  local query="$1"
  curl -fsS --connect-timeout 10 --max-time 30 \
    "${PROMETHEUS_URL}/api/v1/query" \
    --data-urlencode "query=${query}" 2>/dev/null \
    | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    results = data.get('data', {}).get('result', [])
    for r in results:
        metric = r.get('metric', {})
        value = r.get('value', [0, '0'])[1]
        service = metric.get('service', 'unknown')
        instance = metric.get('instance', '').split(':')[0]
        env = metric.get('env', 'unknown')
        label = f'{service}@{instance}' if service == 'tailscale' else service
        print(f'{label}\t{env}\t{value}')
except Exception as e:
    print(f'ERROR: {e}', file=sys.stderr)
" 2>/dev/null || true
}

format_age() {
  local ts="$1"
  local now
  now=$(date +%s)
  local diff=$(( now - ${ts%.*} ))
  if [[ ${diff} -lt 3600 ]]; then
    echo "$((diff / 60))m ago"
  elif [[ ${diff} -lt 86400 ]]; then
    echo "$((diff / 3600))h ago"
  else
    echo "$((diff / 86400))d ago"
  fi
}

format_size() {
  local bytes="$1"
  bytes="${bytes%.*}"
  if [[ ${bytes} -ge 1073741824 ]]; then
    echo "$((bytes / 1073741824)) GB"
  elif [[ ${bytes} -ge 1048576 ]]; then
    echo "$((bytes / 1048576)) MB"
  elif [[ ${bytes} -ge 1024 ]]; then
    echo "$((bytes / 1024)) KB"
  else
    echo "${bytes} B"
  fi
}

echo "Generating backup health summary for ${ENV}..." >&2

{
  echo "Subject: [${ENV}] Weekly Backup Health — $(date +%Y-%m-%d)"
  echo ""
  echo "Backup Health Report — ${ENV} — $(date +%Y-%m-%d)"
  echo "═══════════════════════════════════════════"
  echo ""
  printf "%-20s %-15s %-12s %-10s\n" "Service" "Last Backup" "Size" "Status"
  echo "─────────────────────────────────────────────────────────────"

  # Query backup metrics
  timestamps=$(query_prometheus 'backup_last_success_timestamp')
  sizes=$(query_prometheus 'backup_last_size_bytes')
  statuses=$(query_prometheus 'backup_last_status')

  if [[ -n "${timestamps}" ]]; then
    while IFS=$'\t' read -r service env ts; do
      [[ "${env}" != "${ENV}" ]] && continue
      age=$(format_age "${ts}")

      local_size="?"
      while IFS=$'\t' read -r s e v; do
        if [[ "${s}" == "${service}" && "${e}" == "${env}" ]]; then
          local_size=$(format_size "${v}")
          break
        fi
      done <<< "${sizes}"

      local_status="? UNKNOWN"
      while IFS=$'\t' read -r s e v; do
        if [[ "${s}" == "${service}" && "${e}" == "${env}" ]]; then
          if [[ "${v}" == "1" ]]; then
            local_status="✓ OK"
          else
            local_status="✗ FAILED"
          fi
          break
        fi
      done <<< "${statuses}"

      printf "%-20s %-15s %-12s %-10s\n" "${service}" "${age}" "${local_size}" "${local_status}"
    done <<< "${timestamps}"
  else
    echo "  (no backup metrics available yet)"
  fi

  echo ""

  # Drill status
  drill_statuses=$(query_prometheus 'backup_drill_last_status')
  if [[ -n "${drill_statuses}" ]]; then
    echo "Restore Drills:"
    while IFS=$'\t' read -r service env status; do
      [[ "${env}" != "${ENV}" ]] && continue
      if [[ "${status}" == "1" ]]; then
        echo "  ${service}: PASSED"
      else
        echo "  ${service}: FAILED"
      fi
    done <<< "${drill_statuses}"
  fi

  echo ""
  echo "Next summary: $(date -d '+7 days' +%Y-%m-%d 2>/dev/null || date +%Y-%m-%d) 08:00 UTC"
} > "${SUMMARY_FILE}"

cat "${SUMMARY_FILE}"

{% if backup_alert_email | default('') | trim != '' %}
# Send via mail if available
if command -v mail >/dev/null 2>&1; then
  mail -s "[${ENV}] Weekly Backup Health — $(date +%Y-%m-%d)" "{{ backup_alert_email }}" < "${SUMMARY_FILE}"
  echo "Summary emailed to {{ backup_alert_email }}" >&2
elif command -v msmtp >/dev/null 2>&1; then
  msmtp "{{ backup_alert_email }}" < "${SUMMARY_FILE}"
  echo "Summary emailed to {{ backup_alert_email }}" >&2
fi
{% endif %}

rm -f "${SUMMARY_FILE}"
echo "Weekly backup summary complete." >&2
