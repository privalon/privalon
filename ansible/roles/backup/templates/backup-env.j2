# Backup environment file for {{ inventory_hostname }}
# Generated by Ansible — do not edit manually.

RESTIC_PASSWORD="{{ backup_restic_password }}"
RESTIC_CACHE_DIR="{{ backup_cache_dir }}"
BACKUP_ENV="{{ backup_env }}"

# Primary backend
BACKUP_PRIMARY_ENDPOINT="{{ backup_backends[0].endpoint }}"
BACKUP_PRIMARY_BUCKET="{{ backup_backends[0].bucket }}"
BACKUP_PRIMARY_ACCESS_KEY="{{ backup_backends[0].access_key }}"
BACKUP_PRIMARY_SECRET_KEY="{{ backup_backends[0].secret_key }}"

{% if backup_backends | length > 1 %}
# Secondary backend
BACKUP_SECONDARY_ENDPOINT="{{ backup_backends[1].endpoint }}"
BACKUP_SECONDARY_BUCKET="{{ backup_backends[1].bucket }}"
BACKUP_SECONDARY_ACCESS_KEY="{{ backup_backends[1].access_key }}"
BACKUP_SECONDARY_SECRET_KEY="{{ backup_backends[1].secret_key }}"
{% endif %}
