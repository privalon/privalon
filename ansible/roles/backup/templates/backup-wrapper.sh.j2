#!/usr/bin/env bash
set -euo pipefail
export PATH="/usr/local/bin:$PATH"

# Backup wrapper for {{ item.service_name }}
# Generated by Ansible — do not edit manually.
#
# Flow:
#   1. Source environment
#   2. Run pre-backup hooks
#   3. restic backup → primary backend
#   4. restic backup → secondary backend
#   5. restic forget --prune (both backends)
#   6. Run post-backup hooks
#   7. Write node_exporter metrics

SERVICE="{{ item.service_name }}"
ENV="{{ backup_env }}"
CONFIG="{{ backup_config_dir }}/{{ item.service_name }}.yml"
METRICS_DIR="{{ backup_textfile_dir }}"
METRICS_FILE="${METRICS_DIR}/backup_${SERVICE}.prom"
CACHE_DIR="{{ backup_cache_dir }}"
LOCK_FILE="/var/run/backup-${SERVICE}.lock"

# Source credentials
source {{ backup_base_dir }}/.env

# Primary backend
export RESTIC_REPOSITORY="s3:{{ backup_backends[0].endpoint }}/{{ backup_backends[0].bucket }}/${ENV}/{% if item.service_name == 'tailscale' %}{{ item.service_name }}-{{ inventory_hostname }}{% else %}${SERVICE}{% endif %}"
export RESTIC_PASSWORD="{{ backup_restic_password }}"
export AWS_ACCESS_KEY_ID="{{ backup_backends[0].access_key }}"
export AWS_SECRET_ACCESS_KEY="{{ backup_backends[0].secret_key }}"
export RESTIC_CACHE_DIR="${CACHE_DIR}"

# Secondary backend
SECONDARY_REPO="s3:{{ backup_backends[1].endpoint }}/{{ backup_backends[1].bucket }}/${ENV}/{% if item.service_name == 'tailscale' %}{{ item.service_name }}-{{ inventory_hostname }}{% else %}${SERVICE}{% endif %}"
SECONDARY_ACCESS_KEY="{{ backup_backends[1].access_key }}"
SECONDARY_SECRET_KEY="{{ backup_backends[1].secret_key }}"

# Retention policy
{% set retention = item.retention | default({}) %}
KEEP_HOURLY="{{ retention.keep_hourly | default(backup_retention_keep_hourly) }}"
KEEP_DAILY="{{ retention.keep_daily | default(backup_retention_keep_daily) }}"
KEEP_WEEKLY="{{ retention.keep_weekly | default(backup_retention_keep_weekly) }}"
KEEP_MONTHLY="{{ retention.keep_monthly | default(backup_retention_keep_monthly) }}"
KEEP_YEARLY="{{ retention.keep_yearly | default(backup_retention_keep_yearly) }}"

# Prevent concurrent runs
exec 200>"${LOCK_FILE}"
if ! flock -n 200; then
  echo "[backup][${SERVICE}] Another backup is already running; skipping." >&2
  exit 0
fi

start_time=$(date +%s)
status=0
size=0

cleanup() {
  local end_time
  end_time=$(date +%s)
  local duration=$(( end_time - start_time ))

  # Write metrics for node_exporter textfile collector
  mkdir -p "${METRICS_DIR}"
  cat > "${METRICS_FILE}.tmp" <<METRICS
# HELP backup_last_success_timestamp Unix timestamp of last successful backup
# TYPE backup_last_success_timestamp gauge
backup_last_success_timestamp{service="${SERVICE}",env="${ENV}"} $([ "${status}" -eq 1 ] && date +%s || echo 0)
# HELP backup_last_size_bytes Size of last backup snapshot in bytes
# TYPE backup_last_size_bytes gauge
backup_last_size_bytes{service="${SERVICE}",env="${ENV}"} ${size}
# HELP backup_last_duration_seconds Duration of last backup run in seconds
# TYPE backup_last_duration_seconds gauge
backup_last_duration_seconds{service="${SERVICE}",env="${ENV}"} ${duration}
# HELP backup_last_status Status of last backup (1=success, 0=failure)
# TYPE backup_last_status gauge
backup_last_status{service="${SERVICE}",env="${ENV}"} ${status}
METRICS
  mv "${METRICS_FILE}.tmp" "${METRICS_FILE}"
}
trap cleanup EXIT

echo "[backup][${SERVICE}] Starting backup at $(date -u +%Y-%m-%dT%H:%M:%SZ)"

# ── Pre-backup hooks ──
{% for hook in item.pre_backup | default([]) %}
echo "[backup][${SERVICE}] Pre-hook: {{ hook.name }}"
{{ hook.command }}
{% endfor %}

# ── Backup to primary backend ──
echo "[backup][${SERVICE}] Backing up to primary backend..."
restic backup \
  --retry-lock 60s \
  --tag "${ENV}" \
  --tag "${SERVICE}" \
{% for target in item.targets %}
{% for exclude in target.exclude | default([]) %}
  --exclude "{{ exclude }}" \
{% endfor %}
  "{{ target.path }}" \
{% endfor %}
  --cleanup-cache

# Get snapshot size
size=$(restic stats latest --json 2>/dev/null | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    print(data.get('total_size', 0))
except:
    print(0)
" 2>/dev/null || echo 0)

# ── Backup to secondary backend ──
echo "[backup][${SERVICE}] Backing up to secondary backend..."
timeout 120 env \
  AWS_ACCESS_KEY_ID="${SECONDARY_ACCESS_KEY}" \
  AWS_SECRET_ACCESS_KEY="${SECONDARY_SECRET_KEY}" \
  RESTIC_REPOSITORY="${SECONDARY_REPO}" \
  RESTIC_PASSWORD="${RESTIC_PASSWORD}" \
  RESTIC_CACHE_DIR="${CACHE_DIR}" \
  restic backup \
    --retry-lock 60s \
    --tag "${ENV}" \
    --tag "${SERVICE}" \
{% for target in item.targets %}
{% for exclude in target.exclude | default([]) %}
    --exclude "{{ exclude }}" \
{% endfor %}
    "{{ target.path }}" \
{% endfor %}
  --cleanup-cache

# ── Prune primary ──
echo "[backup][${SERVICE}] Pruning primary backend..."
restic forget --prune \
  --retry-lock 60s \
  --keep-hourly "${KEEP_HOURLY}" \
  --keep-daily "${KEEP_DAILY}" \
  --keep-weekly "${KEEP_WEEKLY}" \
  --keep-monthly "${KEEP_MONTHLY}" \
  --keep-yearly "${KEEP_YEARLY}" \
  --cleanup-cache

# ── Prune secondary ──
echo "[backup][${SERVICE}] Pruning secondary backend..."
timeout 120 env \
  AWS_ACCESS_KEY_ID="${SECONDARY_ACCESS_KEY}" \
  AWS_SECRET_ACCESS_KEY="${SECONDARY_SECRET_KEY}" \
  RESTIC_REPOSITORY="${SECONDARY_REPO}" \
  RESTIC_PASSWORD="${RESTIC_PASSWORD}" \
  RESTIC_CACHE_DIR="${CACHE_DIR}" \
  restic forget --prune \
    --retry-lock 60s \
    --keep-hourly "${KEEP_HOURLY}" \
    --keep-daily "${KEEP_DAILY}" \
    --keep-weekly "${KEEP_WEEKLY}" \
    --keep-monthly "${KEEP_MONTHLY}" \
    --keep-yearly "${KEEP_YEARLY}" \
    --cleanup-cache

# ── Post-backup hooks ──
{% for hook in item.post_backup | default([]) %}
echo "[backup][${SERVICE}] Post-hook: {{ hook.name }}"
{{ hook.command }}
{% endfor %}

status=1
echo "[backup][${SERVICE}] Backup completed successfully at $(date -u +%Y-%m-%dT%H:%M:%SZ)"
