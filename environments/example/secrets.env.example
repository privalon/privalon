# ═══════════════════════════════════════════════════════════════════════
# Secrets for this environment.
# ═══════════════════════════════════════════════════════════════════════
#
# Setup:
#   cp secrets.env.example secrets.env   # then fill in real values
#
# This file is auto-sourced by deploy.sh (set -a / source / set +a).
# All variables become environment variables visible to both Terraform
# (via the TF_VAR_ prefix) and Ansible (via lookup('env', ...)).
#
# NEVER commit secrets.env — it is gitignored.
# ═══════════════════════════════════════════════════════════════════════

# ── ThreeFold Grid credentials ─────────────────────────────────────────
# Your TFChain wallet mnemonic (12 words). Used by Terraform to deploy
# VMs, networks, and public IPs on the ThreeFold Grid.
# Generate one at https://dashboard.grid.tf/ → "Create Account".
TF_VAR_tfgrid_mnemonic="your twelve word mnemonic phrase here"

# ── Monitoring & Services ────────────────────────────────────────────
# Shared initial admin password for all internal services: Grafana, Prometheus, Backrest.
# After first login, change the password in each service UI.
SERVICES_ADMIN_PASSWORD=change-me

# ── Backup (Restic + S3) ──────────────────────────────────────────────
# Required when backup_enabled=true in group_vars/all.yml.
# Both a primary AND secondary backend are mandatory — the deploy will fail
# if either is missing. Use two different providers for true redundancy.
#
# Master encryption password for all Restic repositories.
# Lost password = lost backups. Store it in your password manager.
RESTIC_PASSWORD=
#
# Primary backend — AWS S3 (endpoint: s3.amazonaws.com)
# Create an IAM user with s3:PutObject/GetObject/DeleteObject/ListBucket
# scoped to your backup bucket.
BACKUP_S3_PRIMARY_ACCESS_KEY=
BACKUP_S3_PRIMARY_SECRET_KEY=
#
# Secondary backend — required for disaster-recovery redundancy.
# Use a different provider/region from primary (e.g. Hetzner Object Storage).
# Create credentials at https://console.hetzner.cloud/ → Object Storage → S3 credentials.
BACKUP_S3_SECONDARY_ACCESS_KEY=
BACKUP_S3_SECONDARY_SECRET_KEY=

# ── DNS automation (optional — Namecheap API) ─────────────────────────
# When set, deploy.sh will auto-update DNS A records after terraform apply.
# The same credentials are also reused when internal_service_tls_mode=namecheap
# so the gateway can issue wildcard DNS-01 certificates for *.in.<base_domain>.
# Leave unset to manage DNS manually.
# Domain and subdomain config lives in group_vars/all.yml (base_domain, headscale_subdomain).
#
# NAMECHEAP_API_USER=your-namecheap-username
# NAMECHEAP_API_KEY=your-api-key

# ── Future services ────────────────────────────────────────────────────
# Add secrets for new services here as they are deployed.
# VAULTWARDEN_ADMIN_TOKEN=
# SMTP_PASSWORD=
# MATRIX_SHARED_SECRET=
